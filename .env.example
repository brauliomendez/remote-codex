TELEGRAM_BOT_TOKEN=123456789:your-telegram-bot-token
CODEX_COMMAND=codex
CODEX_BASE_ARGS=
CODEX_DEFAULT_WORKDIR=/root/code
CODEX_ALLOWED_ROOTS=/root/code
CODEX_MODEL=gpt-5.4
CODEX_SANDBOX=workspace-write
CODEX_SKIP_GIT_REPO_CHECK=true
CODEX_ENABLE_WEB_SEARCH=false
STATE_DB_PATH=data/telegram_codex_state.sqlite3
